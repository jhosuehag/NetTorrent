<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/colorSurface"
    android:paddingBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="12dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Engine Logs"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="18sp"
            android:fontFamily="monospace"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_log_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_rounded_section"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="0 lines"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="11sp"
            android:fontFamily="monospace"/>

        <ImageButton
            android:id="@+id/btn_clear_logs"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_delete"
            android:tint="@color/error_red"
            android:contentDescription="Clear logs"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="4dp"
        android:background="@color/divider_grey"/>

    <ScrollView
        android:id="@+id/scroll_logs"
        android:layout_width="match_parent"
        android:layout_height="380dp"
        android:fillViewport="true"
        android:overScrollMode="ifContentScrolls">

        <TextView
            android:id="@+id/tv_logs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:text="Waiting for engine events..."
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="11.5sp"
            android:fontFamily="monospace"
            android:lineSpacingExtra="2dp"
            android:textIsSelectable="true"/>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_copy_logs"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Copy All Logs"
            android:textColor="?attr/colorPrimary"
            app:strokeColor="?attr/colorOutline"
            app:strokeWidth="1dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_close_logs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Close"
            android:textColor="?android:attr/textColorPrimary"
            app:backgroundTint="?attr/colorSurfaceVariant"/>
    </LinearLayout>

</LinearLayout>
